# Environment Variables for Policy Brief Analysis Pipeline

# OpenAI Configuration (REQUIRED)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-2024-08-06

# Pipeline Configuration (OPTIONAL)
# Uncomment and modify as needed

# Maximum number of concurrent workers 
# MAX_WORKERS=4

# Force reprocessing of all files (ignore cache)
# FORCE_REPROCESS=false

# Enable verbose logging
# VERBOSE=true

# Custom configuration directory
# CONFIG_DIR=./config

# Custom output directory  
# OUTPUT_DIR=./out

# PDF Processing Options
# MAX_PDF_SIZE_MB=50
# PDF_EXTRACT_METHOD=pymupdf

# LLM Parameters
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=4000
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=3

# Frame Detection Parameters
# MIN_FRAME_CONFIDENCE=0.7
# MAX_SPANS_PER_FRAME=5

# Recommendation Extraction Parameters  
# MIN_REC_CONFIDENCE=0.6
# MAX_RECOMMENDATIONS=10